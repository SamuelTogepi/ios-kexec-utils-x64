<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Basic Debugging & Task Ports -->
	<key>get-task-allow</key>
	<true/>
	<key>task_for_pid-allow</key>
	<true/>
	
	<!-- Critical for tfp0 (kernel_task) access on iOS 9/10+ -->
	<key>com.apple.system-task-ports</key>
	<true/>
	<key>com.apple.private.kernel.get-task</key>
	<true/>

	<!-- Bypasses AMFI / Library Validation -->
	<key>run-unsigned-code</key>
	<true/>
	<key>com.apple.private.skip-library-validation</key>
	<true/>

	<!-- Tells the kernel this is a trusted system-level binary -->
	<key>platform-application</key>
	<true/>

	<!-- Allows the binary to manage power state (IOPMSleepSystem) -->
	<key>com.apple.private.iokit.power-management</key>
	<true/>

	<!-- Optional but helpful: Allows reading/writing anywhere in the filesystem if needed -->
	<key>com.apple.private.security.no-container</key>
	<true/>
	<key>com.apple.private.security.no-sandbox</key>
	<true/>
</dict>
</plist>
